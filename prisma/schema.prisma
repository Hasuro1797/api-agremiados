// ============================================
// ENUMS - FACTURACIÓN ELECTRÓNICA SUNAT
// ============================================

enum SunatDocType {
  FACTURA // 01 - Factura
  BOLETA // 03 - Boleta de venta
  NOTA_CREDITO // 07 - Nota de crédito
  NOTA_DEBITO // 08 - Nota de débito
}

enum SunatStatus {
  NOT_APPLICABLE // factura interna, no enviada a SUNAT
  PENDING // en cola para procesar
  PROCESSING // generando/firmando XML
  SIGNED // XML firmado, listo para enviar
  SENT // enviada a SUNAT, esperando respuesta
  ACCEPTED // SUNAT aceptó (CDR recibido)
  OBSERVED // SUNAT aceptó con observaciones (códigos 100-1999)
  REJECTED // SUNAT rechazó
  ERROR // error interno o de conexión (reintentable)
  VOIDED // anulado (comunicación de baja)
}

enum BillingDocType {
  XML_SIGNED // XML firmado listo para envío y archivado
  CDR_ZIP // ZIP de CDR devuelto por SUNAT
  PDF // PDF generado con pdfmake
}

enum ActivityAudience {
  MEMBERS_ONLY // solo miembros registrados
  MEMBERS_AND_GUESTS // miembros + invitados con sponsor
  OPEN // todos: miembros, invitados y externos sin sponsor
}

enum AttendeeType {
  MEMBER // User registrado (userId requerido)
  INVITED // traído por un miembro (documentNumber + sponsorAttendeeId requeridos)
  EXTERNAL // externo directo (documentNumber requerido, sin sponsor)
}

enum DiscountTargetType {
  ALL // aplica a todos los miembros activos automáticamente
  BY_CATEGORY // aplica a categorías en targetCategories[]
  SPECIFIC_USERS // solo usuarios en tabla DiscountUser
}
